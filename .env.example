# Copia este archivo como .env y rellena los valores antes de ejecutar
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=tudominio.com,www.tudominio.com
# DATABASE_URL=postgres://user:pass@localhost:5432/skedyclass

# ── AI Provider (Asistente IA + Lab Pedagógico) ──────────────────────────
AI_PROVIDER=groq  # groq | gemini | anthropic

# ── Groq (GRATIS, ultra rápido — recomendado) ─────────────────────────────
# Obtén tu clave gratis en: https://console.groq.com/keys
GROQ_API_KEY=TU_API_KEY_AQUI
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Gemini (alternativa gratuita) ──────────────────────────────────
GEMINI_API_KEY=TU_API_KEY_AQUI
GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic (opcional) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=TU_API_KEY_AQUI

# ── SMTP — Alertas automáticas de calificaciones ─────────────────────────
# Gmail: necesitas una "Contraseña de aplicación" (no tu contraseña normal)
# Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
DEFAULT_FROM_EMAIL=SkedyClass <tu_correo@gmail.com>

# SendGrid (alternativa):
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.xxxxxxxxxxxx
